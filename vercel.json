{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "functions": {
    "app/api/documents/upload/prepare/route.ts": {
      "maxDuration": 300
    },
    "app/api/documents/upload/complete/route.ts": {
      "maxDuration": 300
    },
    "app/api/documents/upload/direct/route.ts": {
      "maxDuration": 300
    }
  }
}
