# Turso (use file:local.db for local dev without Turso cloud)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# OpenRouter — swap model names freely
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Performance tuning (optional)
OPENROUTER_CONCURRENCY=10
OPENROUTER_BATCH_SIZE=3

# Upload size limit in megabytes (client + server must agree)
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# Cloudflare R2 — ephemeral PDF staging (browser PUT via presigned URL).
# Create an R2 bucket + API token in Cloudflare Dashboard → R2 → Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional override (defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com)
# R2_ENDPOINT=

# Production URL (OpenRouter referer; optional locally)
NEXT_PUBLIC_APP_URL=https://pdf-summarizer-read-summ.vercel.app

# Local dev without R2 credentials: uses same-origin upload automatically.
# Local dev with R2 credentials: uses R2 automatically (NEXT_PUBLIC_R2_UPLOADS_ENABLED is set in next.config.ts).
# Force direct upload everywhere: NEXT_PUBLIC_UPLOAD_VIA_SERVER=true
# Force R2 upload everywhere (fails if R2 is missing): NEXT_PUBLIC_UPLOAD_VIA_SERVER=false

# Seconds of AI work per serverless invocation before chaining /continue (default 50).
# PROCESS_TIME_BUDGET_SEC=50
