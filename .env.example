# Turso (use file:local.db for local dev without Turso cloud)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# OpenRouter — swap model names freely
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Performance tuning (optional)
OPENROUTER_CONCURRENCY=10
OPENROUTER_BATCH_SIZE=3

# Upload size limit in megabytes. Vercel serverless caps the request body at
# ~4.5 MB so the default is 4. Raise this only when self-hosting behind a
# proxy/runtime that accepts larger payloads. Must be NEXT_PUBLIC_ so the
# client and server agree on the limit.
NEXT_PUBLIC_MAX_UPLOAD_MB=4
