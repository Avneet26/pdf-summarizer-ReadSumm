# Turso (use file:local.db for local dev without Turso cloud)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# OpenRouter — swap model names freely
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Performance tuning (optional)
OPENROUTER_CONCURRENCY=10
OPENROUTER_BATCH_SIZE=3

# Upload size limit in megabytes (client + server must agree)
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# Vercel Blob — created automatically when you add a Blob store in Vercel → Storage.
# For local dev with Blob uploads: run `vercel env pull` in this folder.
BLOB_READ_WRITE_TOKEN=

# Production URL (OpenRouter referer; optional locally)
NEXT_PUBLIC_APP_URL=https://pdf-summarizer-read-summ.vercel.app

# Local dev without Blob: uses same-origin upload (no token needed).
# NEXT_PUBLIC_UPLOAD_VIA_SERVER=true

# Seconds of AI work per serverless invocation before chaining /continue (default 50).
# PROCESS_TIME_BUDGET_SEC=50
