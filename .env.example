# Turso (use file:local.db for local dev without Turso cloud)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# OpenRouter — swap model names freely
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Performance tuning (optional)
OPENROUTER_CONCURRENCY=10
OPENROUTER_BATCH_SIZE=3

# Upload size limit in megabytes. The browser uploads PDFs straight to
# Firebase Storage via a signed URL, so the Vercel serverless body cap does
# not apply. The server still downloads the staged file to process it, so
# keep this within a reasonable bound. Must be NEXT_PUBLIC_ so the client
# and server agree on the limit.
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# Firebase Storage (used as ephemeral upload staging).
# Create a service account in the Firebase console (Project settings →
# Service accounts → Generate new private key), then copy the values from
# the downloaded JSON. The private key's literal "\n" sequences are
# converted to real newlines at runtime, so the single-line form below works.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
