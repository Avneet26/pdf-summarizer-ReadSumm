{
  "name": "pdf-reader",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "vercel-build": "node scripts/vercel-prebuild.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
